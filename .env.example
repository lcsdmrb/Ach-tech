# ──────────────────────────────────────────────
# FICHIER .env.local  (à créer dans ce dossier)
# Ne jamais committer ce fichier sur GitHub !
# ──────────────────────────────────────────────

# Clé API Resend pour l'envoi d'emails
# → Créer un compte gratuit sur https://resend.com
# → Aller dans "API Keys" et générer une clé
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Adresse email qui RECEVRA les devis
CONTACT_TO_EMAIL=votre@email.be

# Adresse email expéditrice (doit être vérifiée dans Resend)
# Sur le plan gratuit, utiliser : onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev
