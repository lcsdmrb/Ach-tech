# URL publique du site (utilisée pour la vérification CSRF)
# Sur Vercel : ajouter dans Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://ach-tech.com

# Clé API Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email de destination des devis reçus
CONTACT_TO_EMAIL=info@ach-tech.com

# Email expéditeur vérifié dans Resend (votre domaine ou onboarding@resend.dev sur plan gratuit)
CONTACT_FROM_EMAIL=noreply@ach-tech.com

# Environnement (development | production)
NODE_ENV=production
